Include /Users/jon/.colima/ssh_config

# Proxmox Cluster Nodes
Host pve 192.168.1.107
  HostName 192.168.1.107
  User root

Host lenovo 192.168.1.143
  HostName 192.168.1.143
  User root

Host latitude 192.168.1.147
  HostName 192.168.1.147
  User root

Host pavilion 192.168.1.146
  HostName 192.168.1.146
  User root

Host asus 192.168.1.154
  HostName 192.168.1.154
  User root

# Enable SSH agent forwarding for homelab nodes
# and set compatible terminal b/c i use ghostty
Host pve lenovo latitude pavilion asus
  ForwardAgent yes
  SetEnv TERM=xterm-256color

# Ubuntu Saltbox VM
Host sb 192.168.1.130
  HostName 192.168.1.130
  User zhengers 
  SetEnv TERM=xterm-256color

# External Services
Host github.com
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519
  AddKeysToAgent yes
  UseKeychain yes

# ssh agent forwarding for ocf hpc
Host gpus
    HostName hpcctl.ocf.berkeley.edu
    User johnathon
    ForwardAgent Yes
    AddKeysToAgent Yes
    IdentityFile ~/.ssh/id_ed25519
    SetEnv TERM=xterm-256color

Host decal
    HostName johnathon.decal.ocfhosted.com
    User johnathon
    ForwardAgent Yes

# xmap ec2
Host xmap
  HostName 13.230.234.174
  User ubuntu
  IdentityFile /Users/jon/.ssh/johnathan.pem
  IdentitiesOnly yes
  SetEnv TERM=xterm-256color



